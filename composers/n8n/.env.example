# =========================
# Core n8n Configuration
# =========================
N8N_HOST=n8n.yourdomain.com
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://n8n.yourdomain.com/

# Timezone
GENERIC_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata

# =========================
# Database (Postgres)
# =========================
POSTGRES_DB=n8n
POSTGRES_USER=n8n

# =========================
# Redis
# =========================
REDIS_PORT=6379

# =========================
# Execution Mode
# =========================
EXECUTIONS_MODE=queue

# =========================
# Logging / Behavior
# =========================
N8N_LOG_LEVEL=info
N8N_DIAGNOSTICS_ENABLED=false

# =========================
# Versions (pin here)
# =========================
N8N_IMAGE_TAG=1.82.3
POSTGRES_IMAGE_TAG=15
REDIS_IMAGE_TAG=7

# =========================
# Database Type
# =========================
DB_TYPE=postgresdb # Supported values: postgresdb, mysqldb

# =========================
# Data Mode
# =========================
N8N_DEFAULT_BINARY_DATA_MODE=filesystem # Supported values: filesystem, default

# =========================
# Email Configuration (for SMTP)
# =========================
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=SMTP server
N8N_SMTP_PORT=SMTP port
N8N_SMTP_USER=SMTP username
N8N_SMTP_PASS=SMTP password
N8N_SMTP_SENDER=Sender email

# =========================
# N8N Encryption Key (for encrypting credentials)
# =========================
N8N_ENCRYPTION_KEY=your-encryption-key # leave blank on fresh install



